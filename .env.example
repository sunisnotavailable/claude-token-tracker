# Upstream API endpoint — the URL Claude Code was originally pointing to.
# Copy this file to .env and fill in your value.
#
# Examples:
#   Company proxy:   UPSTREAM_URL=https://your-company-proxy.example.com
#   Direct Anthropic: UPSTREAM_URL=https://api.anthropic.com  (this is the default)
UPSTREAM_URL=https://api.anthropic.com
